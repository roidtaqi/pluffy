{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "RAILPACK",
        "watchPatterns": [
            "/pluffy-backend/**"
        ]
    },
    "deploy": {
        "preDeployCommand": [
            "chmod +x ./railway/init-app.sh && sh ./railway/init-app.sh"
        ],
        "healthcheckPath": "/up",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
    }
}

