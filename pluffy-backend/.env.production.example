APP_NAME=PluffyBackend
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

PLUFFY_FRONTEND_URLS=https://pluffy.example.com
PLUFFY_ADMIN_EMAIL=admin@pluffy.cafe
PLUFFY_ADMIN_PASSWORD=change-this-strong-password
PLUFFY_DEMO_USER_PASSWORD=change-this-demo-user-password-or-skip-seeding-demo-user

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pluffy_db
DB_USERNAME=pluffy_user
DB_PASSWORD=change-this-db-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_EXPIRATION=10080

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@pluffy.cafe"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
