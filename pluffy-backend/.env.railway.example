APP_NAME=PluffyBackend
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-service.up.railway.app

PLUFFY_FRONTEND_URLS=https://your-frontend-domain.example
PLUFFY_ADMIN_EMAIL=admin@pluffy.cafe
PLUFFY_ADMIN_PASSWORD=change-this-strong-password
PLUFFY_DEMO_USER_PASSWORD=change-this-demo-user-password-or-skip-demo-seeding

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12
LOG_CHANNEL=stderr
LOG_STDERR_FORMATTER=\Monolog\Formatter\JsonFormatter
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_URL=${{Postgres.DATABASE_URL}}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_EXPIRATION=10080

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS=halo@pluffy.cafe
MAIL_FROM_NAME=${APP_NAME}

VITE_APP_NAME=${APP_NAME}
